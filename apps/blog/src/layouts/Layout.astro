---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
import "../styles.css";

interface Props {
  title?: string;
  description?: string;
}

const { title = SITE_TITLE, description = SITE_DESCRIPTION } = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body class="px-4 pt-20">
    <Header />
    <slot />
    <footer class="-mx-4 mt-16 border-t px-4 py-6 md:mt-24 md:py-10">
      <p class="text-muted mx-auto max-w-5xl font-mono text-xs tracking-wide">
        (c) 2024 Keita Ito. All rights reserved.
      </p>
    </footer>
  </body>
</html>
