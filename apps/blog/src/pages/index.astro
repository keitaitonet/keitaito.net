---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import HeroSection from "../components/HeroSection.astro";
import WorksSection from "../components/WorksSection.astro";
import ActivitiesSection from "../components/ActivitiesSection.astro";
import SkillsSection from "../components/SkillsSection.astro";
import ArticlesSection from "../components/ArticlesSection.astro";

const [activitiesRaw, articlesRaw, skillsRaw, works] = await Promise.all([
  getCollection("activities"),
  getCollection("articles"),
  getCollection("skills"),
  getCollection("works"),
]);

const activities = activitiesRaw.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const articles = articlesRaw.sort(
  (a, b) => b.data.published_at.valueOf() - a.data.published_at.valueOf(),
);
const skills = skillsRaw.sort((a, b) => a.data.name.localeCompare(b.data.name));

const sectionLinks = [
  { href: "#works", label: "Works" },
  { href: "#activities", label: "Activities" },
  { href: "#skills", label: "Skills" },
  { href: "#articles", label: "Articles" },
];
---

<Layout>
  <main>
    <HeroSection />

    <nav class="border-border/50 -mx-4 border-b">
      <ul
        class="mx-auto grid max-w-5xl grid-cols-4 font-mono text-xs uppercase"
      >
        {
          sectionLinks.map(({ href, label }) => (
            <li>
              <a
                href={href}
                class="text-muted hover:text-primary focus-visible:text-primary block py-3 text-center transition"
              >
                {label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <WorksSection works={works} />
    <ActivitiesSection activities={activities} />
    <SkillsSection skills={skills} />
    <ArticlesSection articles={articles} />
  </main>
</Layout>
