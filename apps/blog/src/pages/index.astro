---
import { getCollection } from "astro:content";
import { getImage } from "astro:assets";
import type { ItemList, Person, WithContext } from "schema-dts";
import Layout from "../layouts/Layout.astro";
import HeroSection from "../components/HeroSection.astro";
import WorksSection from "../components/WorksSection.astro";
import ActivitiesSection from "../components/ActivitiesSection.astro";
import SkillsSection from "../components/SkillsSection.astro";
import ArticlesSection from "../components/ArticlesSection.astro";
import profileImage from "../assets/profile.jpg";
import { SITE_SECTIONS } from "../consts";

const [activitiesRaw, articlesRaw, skillsRaw, works] = await Promise.all([
  getCollection("activities"),
  getCollection("articles"),
  getCollection("skills"),
  getCollection("works"),
]);

const activities = activitiesRaw.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const articles = articlesRaw.sort(
  (a, b) => b.data.published_at.valueOf() - a.data.published_at.valueOf(),
);
const skills = skillsRaw.sort((a, b) => a.data.name.localeCompare(b.data.name));

const optimizedProfile = await getImage({ src: profileImage, width: 512 });
const profileImageUrl = new URL(optimizedProfile.src, Astro.site).href;
const siteUrl = new URL("/", Astro.site).href;

const personJsonLd: WithContext<Person> = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "伊藤 啓太",
  alternateName: "Keita Ito",
  jobTitle: "Student",
  url: siteUrl,
  image: profileImageUrl,
  birthDate: "2004-07-09",
  address: {
    "@type": "PostalAddress",
    addressLocality: "Tokyo",
    addressCountry: "JP",
  },
  alumniOf: {
    "@type": "CollegeOrUniversity",
    name: "電気通信大学",
    url: "https://www.uec.ac.jp",
  },
  sameAs: [
    "https://github.com/keitaitonet",
    "https://x.com/keitaitonet",
    "https://zenn.dev/kk79it",
    "https://qiita.com/keitaitonet",
  ],
};

const worksItemList: WithContext<ItemList> = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Works",
  itemListElement: works.map((work, i) => ({
    "@type": "ListItem",
    position: i + 1,
    url: new URL(`/works/${work.id}/`, Astro.site).href,
    name: work.data.title,
  })),
};
---

<Layout jsonLd={[personJsonLd, worksItemList]}>
  <main>
    <HeroSection />

    <nav aria-label="ページ内リンク" class="border-border/50 -mx-4 border-b">
      <ul
        class="mx-auto grid max-w-5xl grid-cols-4 font-mono text-xs uppercase"
      >
        {
          SITE_SECTIONS.map(({ href, label }) => (
            <li>
              <a
                href={href}
                class="text-muted hover:text-primary focus-visible:text-primary block py-3 text-center transition"
              >
                {label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <WorksSection works={works} />
    <ActivitiesSection activities={activities} />
    <SkillsSection skills={skills} />
    <ArticlesSection articles={articles} />
  </main>
</Layout>
