---
import type { CollectionEntry } from "astro:content";
import { format } from "date-fns";
import IconExternalLink from "../assets/icons/external-link.svg";
import IconHeart from "../assets/icons/heart.svg";
import Link from "./Link.astro";
import SectionHeading from "./SectionHeading.astro";

interface Props {
  articles: CollectionEntry<"articles">[];
}

const { articles } = Astro.props;
---

<section
  id="articles"
  aria-labelledby="articles-heading"
  class="mx-auto max-w-5xl py-16"
>
  <SectionHeading id="articles-heading" title="Articles" />
  <ul>
    {
      articles.map((article) => (
        <li class="border-border/50 border-b">
          <Link
            href={article.data.url}
            showIcon={false}
            class="group grid grid-cols-[auto_1fr] items-baseline gap-x-3 gap-y-1 py-5 no-underline [grid-template-areas:'title_title'_'date_meta'] md:grid-cols-[8rem_1fr_auto] md:gap-x-8 md:gap-y-0 md:[grid-template-areas:'date_title_meta']"
          >
            <time
              datetime={format(article.data.published_at, "yyyy-MM-dd")}
              class="text-muted font-mono text-xs tracking-wide [grid-area:date]"
            >
              {format(article.data.published_at, "MMM d, yyyy")}
            </time>
            <h3 class="decoration-primary leading-snug font-medium underline decoration-1 underline-offset-4 [grid-area:title] group-hover:decoration-2 group-focus-visible:decoration-2">
              {article.data.title}
              <IconExternalLink
                class="text-muted ml-1 inline size-3.5 align-middle"
                aria-label="外部リンク"
              />
            </h3>
            <p class="text-muted inline-flex items-center gap-3 font-mono text-xs tracking-wide [grid-area:meta]">
              <span class="uppercase">{article.data.source}</span>
              <span class="inline-flex items-center gap-1">
                <IconHeart class="size-3" aria-label="いいね" />
                {article.data.liked_count}
              </span>
            </p>
          </Link>
        </li>
      ))
    }
  </ul>
</section>
